            "value" : "Site web"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Web サイト"
          }
        }
      }
    },
    "What’s Holding You Back" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was Sie aufhält"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce qui vous freine"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "妨げになっているもの"
          }
        }
      }
    },
    "When enabled, anonymous Intel app metadata from your scans is shared with the RosettaCheck community to help others track Apple Silicon readiness." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, werden anonyme Metadaten zu Intel-Apps aus Ihren Scans mit der RosettaCheck-Community geteilt, um anderen zu helfen, die Apple-Silicon-Bereitschaft zu verfolgen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque cette option est activée, les métadonnées anonymes des apps Intel de vos analyses sont partagées avec la communauté RosettaCheck pour aider les autres à suivre la préparation à Apple Silicon."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、スキャン結果に含まれる Intel App の匿名メタデータが RosettaCheck コミュニティと共有され、他のユーザの Apple Silicon 対応の状況把握に役立てられます。"
          }
        }
      }
    },
    "When enabled, Rosetta Check watches for newly installed apps and sends a notification if an Intel-only app is detected." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, achtet Rosetta Check auf neu installierte Apps und sendet eine Mitteilung, falls eine ausschließlich Intel-basierte App erkannt wird."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque cette option est activée, Rosetta Check surveille les nouvelles apps installées et envoie une notification si une app exclusivement Intel est détectée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、Rosetta Check が新しくインストールされた App を監視し、Intel 専用の App を検出した場合に通知を送信します。"
          }
        }
      }
    },
    "When enabled, scan results are automatically saved to the export location after each scan. MDM administrators can configure the format via a configuration profile." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, werden Scan-Ergebnisse nach jedem Scan automatisch am Exportziel gespeichert. MDM-Administratoren können das Format über ein Konfigurationsprofil festlegen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque cette option est activée, les résultats d’analyse sont automatiquement enregistrés à l’emplacement d’exportation après chaque analyse. Les administrateurs MDM peuvent configurer le format via un profil de configuration."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、スキャン結果は毎回、書き出し先に自動的に保存されます。MDM 管理者は構成プロファイルでフォーマットを設定できます。"
          }
        }
      }
    },
    "Why is it a good replacement? (optional)" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warum ist sie eine gute Alternative? (optional)"
