      }
    },
    "Rosetta Check scans your installed applications and identifies which ones still require Rosetta 2 (Intel emulation) to run on Apple Silicon Macs." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rosetta Check scannt Ihre installierten Anwendungen und erkennt, welche davon noch Rosetta 2 (Intel-Emulation) benötigen, um auf Apple-Silicon-Macs zu laufen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rosetta Check analyse vos applications installées et identifie celles qui nécessitent encore Rosetta 2 (émulation Intel) pour fonctionner sur les Mac Apple Silicon."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rosetta Check はインストール済みのアプリケーションをスキャンし、Apple Silicon Mac で動作するために Rosetta 2 (Intel エミュレーション) をまだ必要とするものを特定します。"
          }
        }
      }
    },
