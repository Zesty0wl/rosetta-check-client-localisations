          "stringUnit" : {
            "state" : "translated",
            "value" : "なぜ良い代替候補だと思いますか?(任意)"
          }
        }
      }
    },
    "Will not work on macOS 28 without Rosetta" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wird unter macOS 28 ohne Rosetta nicht funktionieren"
