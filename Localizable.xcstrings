    "Rosetta Check can start automatically when you log in so it's always monitoring your apps in the background.\n\nYou can change this later in Settings." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rosetta Check kann automatisch bei der Anmeldung starten, um Ihre Apps stets im Hintergrund zu überwachen.\n\nSie können dies später in den Einstellungen ändern."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rosetta Check peut démarrer automatiquement à votre connexion pour surveiller en permanence vos apps en arrière-plan.\n\nVous pourrez modifier ce choix plus tard dans les réglages."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rosetta Check はログイン時に自動で起動し、バックグラウンドで常時 App を監視できます。\n\nこの設定は後で「設定」から変更できます。"
          }
        }
      }
    },
    "Rosetta Check Help" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hilfe zu Rosetta Check"
          }
